# Supabase project settings (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: only needed for server-side writes that must bypass RLS
SUPABASE_SERVICE_ROLE_KEY=

# Gemini (free tier) — used for post generation, transforms, and engagement scoring
GEMINI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Public URL of the deployed app (used for social/OG metadata)
NEXT_PUBLIC_SITE_URL=
